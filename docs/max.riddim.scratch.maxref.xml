<c74object name="max.riddim.scratch">

	<digest>
		Calculate and add scratch values to max.riddim.brain
	</digest>

	<description>
		Calculates scratch data from incoming .brain OSC data, stores both values inside the maxriddim max/ dictionary.
		<br />
		Adds to maxriddim dict:
		<br />
		max/turntable1/scratch - 0/1 state boolean that recognizes when a scratch beggins and ends.
		<br />
		max/turntable1/scratch_dir - float for scratch direction (&gt; 0. clockwise, &lt; 0. counter-clockwise).
	</description>
	
	<!--METADATA-->
	<metadatalist>
